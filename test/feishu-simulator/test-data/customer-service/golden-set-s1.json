{
  "cases": [
    {
      "name": "F01-EC是什么",
      "message": "EC 是什么？能帮我做什么？",
      "assert": {
        "containsAny": ["企业", "AI 助手", "助手", "平台"],
        "notContains": "error"
      },
      "tags": ["functional", "easy", "S1"]
    },
    {
      "name": "F02-支持哪些IM",
      "message": "EC 支持哪些即时通讯工具？",
      "assert": {
        "containsAny": ["飞书", "IM", "渠道", "通讯"],
        "notContains": "error"
      },
      "tags": ["functional", "easy", "S1"]
    },
    {
      "name": "F03-SaaS还是私有化",
      "message": "EC 有没有 SaaS 版本？我需要自己搭服务器吗？",
      "assert": {
        "containsAny": ["SaaS", "私有化", "服务器", "安装"],
        "notContains": "error"
      },
      "tags": ["functional", "easy", "S1"]
    },
    {
      "name": "F04-添加Skill",
      "message": "我想给我的 EC 助手添加一个新的 Skill，应该怎么操作？",
      "assert": {
        "containsAny": ["Skill", "插件", "技能", "安装"],
        "notContains": "error"
      },
      "tags": ["functional", "medium", "S1"]
    },
    {
      "name": "F05-多租户隔离",
      "message": "多个部门共用一个 EC 账户，数据会不会互相看到？",
      "assert": {
        "containsAny": ["隔离", "多租户", "权限", "独立"],
        "notContains": "error"
      },
      "tags": ["functional", "medium", "S1"]
    },
    {
      "name": "F06-成本统计",
      "message": "我怎么看到团队每个月用了多少 AI？有成本统计吗？",
      "assert": {
        "containsAny": ["成本", "Token", "用量", "追踪", "统计"],
        "notContains": "error"
      },
      "tags": ["functional", "medium", "S1"]
    },
    {
      "name": "F07-飞书不回复排查",
      "message": "在飞书里发消息给 EC 助手它没有回复，可能是什么原因？",
      "assert": {
        "containsAny": ["配置", "权限", "检查", "连接"],
        "notContains": "error"
      },
      "tags": ["functional", "medium", "S1"]
    },
    {
      "name": "F08-Token计费",
      "message": "EC 的 Token 是怎么计费的？每次对话消耗多少？",
      "assert": {
        "containsAny": ["Token", "计费", "模型", "消耗"],
        "notContains": "error"
      },
      "tags": ["functional", "hard", "S1"]
    },
    {
      "name": "F09-和Dify的区别",
